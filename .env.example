# ============================================================
# WxO Agent Evaluator — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env

# --- AWS ---
# AWS region where the Lambdas, Step Functions, S3, DynamoDB will live
AWS_REGION=us-east-1

# --- watsonx Orchestrate ---
# Your WxO instance URL (find it in your Orchestrate settings)
# Example: https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>
WXO_INSTANCE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>

# Your WxO API key (used by Lambdas to call the Orchestrate API for evaluation runs)
WXO_API_KEY=<your-wxo-api-key>

# Optional: name of the orchestrate CLI environment to deploy agents/tools to
# Run `orchestrate env list` to see available environments
WXO_ENV_NAME=us-south

# --- LLM-as-Judge model ---
# Model used by the Analyze stage for LLM-as-Judge + RCA generation.
# This must be a model your WxO instance has access to via the Orchestrate Gateway.
# Examples:
#   meta-llama/llama-3-3-70b-instruct
#   openai/gpt-oss-120b
JUDGE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# --- Optional: OpenAI key (only needed if you swap LLM-as-Judge to OpenAI) ---
# OPENAI_API_KEY=<your-openai-key>
